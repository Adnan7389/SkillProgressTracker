NODE_ENV=development
PORT=5000

# MongoDB Connection String from MongoDB Atlas (Day 1)
# Example: mongodb+srv://username:password@cluster.mongodb.net/skill-tracker
MONGODB_URI=mongodb+srv://user_db:db_password@cluster1.uebtzsf.mongodb.net/?appName=Cluster1/

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-generated-secret-here
BETTER_AUTH_URL=http://localhost:5000

# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

FRONTEND_URL=http://localhost:5173
